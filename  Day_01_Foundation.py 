        "# DAY 1: THE FOUNDATION\n",
        "import pandas as pd\n",
        "\n",
        "# 1. LISTS (የመረጃ ዝርዝር)\n",
        "names = [\"Abebe\", \"Kebede\", \"Sara\", \"Marta\"]\n",
        "ages = [25, 30, 22, 28]\n",
        "salaries = [5000, 7000, 4500, 8000]\n",
        "cities= [\"Addis Ababa\", \"Bahir Dar\", \"Gondar\", \"Hawassa\"]\n",
        "# 2. DICTIONARY (መረጃን ማገናኘት - Key: Value)\n",
        "# This is how 99% of data starts before it becomes a DataFrame\n",
        "data = {\n",
        "    \"Name\": names,\n",
        "    \"Age\": ages,\n",
        "    \"Salary\": salaries,\n",
        "    \"city\": cities,\n",
        "}\n",
        "\n",
        "print(\"--- RAW DICTIONARY ---\")\n",
        "print(data)\n",
        "# 3. CONVERT TO DATAFRAME (The Magic Step)\n",
        "df = pd.DataFrame(data)\n",
        "\n",
        "print(\"\\n--- PANDAS DATAFRAME (The Table) ---\")\n",
        "print(df)\n",
        "\n",
        "# 4. BASIC INSPECTION (ማየት)\n",
        "print(\"\\n--- Shape (Rows, Columns) ---\")\n",
        "print(df.shape) # (4, 3) ማለት 4 ሰው፣ 3 መረጃ\n",
        "\n",
        "print(\"\\n--- Data Types (ወሳኝ ነው!) ---\")\n",
        "print(df.dtypes) # Object = Text, int64 = Number"
      ],
