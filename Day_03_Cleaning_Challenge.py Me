        "# DAY 3 CHALLENGE: SOLVED & FIXED\n",
        "import numpy as np\n",
        "import pandas as pd  # 1. Fixed 'pandas'\n",
        "\n",
        "# 1. CREATE DIRTY DATA\n",
        "product_data = {\n",
        "    'product': ['tv', 'radio', 'tv', np.nan, 'phone'],\n",
        "    'price': [10000, 500, 10000, 2000, np.nan]\n",
        "}  # 2. Added comma above\n",
        "\n",
        "print(\"--- RAW DATA ---\")\n",
        "df = pd.DataFrame(product_data) # 3. Fixed Indentation\n",
        "print(df)\n",
        "print(\"\\n\")\n",
        "\n",
        "# 2. REMOVE DUPLICATES\n",
        "df_clean = df.drop_duplicates()\n",
        "print(\"--- AFTER REMOVING DUPLICATES ---\")\n",
        "print(df_clean)\n",
        "print(\"\\n\")\n",
        "\n",
        "# 3. HANDLING MISSING PRODUCT (Drop)\n",
        "# ስም የሌለውን እቃ እናጠፋለን\n",
        "df_clean = df_clean.dropna(subset=['product']) # 4. Added quotes ['product']\n",
        "\n",
        "# 4. HANDLING MISSING PRICE (Fill)\n",
        "# ዋጋ የሌለውን በአማካይ እንሞላለን\n",
        "mean_price = df_clean['price'].mean() # 5. Added parentheses ()\n",
        "df_clean['price'] = df_clean['price'].fillna(mean_price) # 6. Fixed spelling 'fillna'\n",
        "\n",
        "print(f\"--- FINAL CLEAN DATA (Filled Price with {mean_price}) ---\")\n",
        "print(df_clean)"
      ]
    }
